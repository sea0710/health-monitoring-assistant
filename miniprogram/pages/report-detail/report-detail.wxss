.container {
  min-height: 100vh;
  padding: 16px;
  padding-bottom: 100px;
  background: #f8faf9;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 16px;
  border-bottom: 1px solid #e5e7eb;
  margin-bottom: 16px;
}

.back-btn {
  display: flex;
  align-items: center;
  padding: 8px;
  margin-left: -8px;
}

.back-icon {
  font-size: 20px;
  color: #14b8a6;
  margin-right: 4px;
}

.back-text {
  font-size: 14px;
  color: #14b8a6;
}

.title {
  font-size: 18px;
  font-weight: 600;
  color: #1f2937;
}

.placeholder {
  width: 60px;
}

.report-info-card {
  background: #ffffff;
  border-radius: 16px;
  padding: 16px;
  margin-bottom: 16px;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid #f3f4f6;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 14px;
  color: #6b7280;
}

.info-value {
  font-size: 14px;
  color: #1f2937;
  font-weight: 500;
}

.indicators-section {
  margin-bottom: 16px;
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 12px;
  display: block;
}

.indicator-card {
  background: #ffffff;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
  border-left: 4px solid #22c55e;
}

.indicator-card.abnormal {
  border-left-color: #f59e0b;
}

.indicator-main {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12px;
}

.indicator-left {
  display: flex;
  flex-direction: column;
}

.indicator-name {
  font-size: 16px;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 4px;
}

.indicator-code {
  font-size: 12px;
  color: #9ca3af;
}

.indicator-right {
  display: flex;
  align-items: baseline;
}

.indicator-value {
  font-size: 24px;
  font-weight: 700;
  color: #1f2937;
}

.indicator-card.abnormal .indicator-value {
  color: #d97706;
}

.indicator-unit {
  font-size: 12px;
  color: #6b7280;
  margin-left: 4px;
}

.indicator-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.reference-range {
  font-size: 12px;
  color: #9ca3af;
}

.indicator-status {
  display: flex;
  align-items: center;
}

.status-badge {
  padding: 4px 12px;
  border-radius: 12px;
  font-size: 12px;
  font-weight: 500;
}

.status-badge.normal {
  background: rgba(34, 197, 94, 0.1);
  color: #16a34a;
}

.status-badge.I {
  background: rgba(245, 158, 11, 0.1);
  color: #d97706;
}

.status-badge.II {
  background: rgba(249, 115, 22, 0.1);
  color: #ea580c;
}

.status-badge.III {
  background: rgba(234, 88, 12, 0.1);
  color: #c2410c;
}

.status-badge.IV {
  background: rgba(220, 38, 38, 0.1);
  color: #dc2626;
}

.trend-link {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #ffffff;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 16px;
}

.trend-text {
  font-size: 14px;
  color: #14b8a6;
  font-weight: 500;
}

.trend-arrow {
  font-size: 18px;
  color: #14b8a6;
}

.disclaimer-card {
  background: rgba(245, 158, 11, 0.05);
  border: 1px solid rgba(245, 158, 11, 0.2);
  border-radius: 12px;
  padding: 16px;
}

.disclaimer-title {
  font-size: 14px;
  font-weight: 600;
  color: #d97706;
  margin-bottom: 8px;
  display: block;
}

.disclaimer-content {
  font-size: 12px;
  color: #92400e;
  line-height: 1.6;
}
