/* ============================================   报告详情页面 - 视觉优化样式   设计原则：温暖、可靠、简洁   特点：数据展示页面，需要清晰的信息层级   对齐设计稿：ReportDetailPage.tsx   ============================================ */

/* ============================================   1. 页面容器   ============================================ */
.container {
  min-height: 100vh;
  background: var(--background);
  padding: var(--spacing-lg);
  animation: fadeIn 0.3s ease-out;
  display: flex;
  flex-direction: column;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ============================================   2. 报告基础信息卡片   ============================================ */
.info-card {
  background: var(--surface);
  border-radius: 20px;
  padding: 20px;
  margin-bottom: var(--spacing-lg);
  box-shadow: var(--shadow-sm);
  border: none;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-md) 0;
}

.info-row:first-child {
  padding-top: 0;
}

.info-row:last-child {
  padding-bottom: 0;
}

.info-label {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
}

.info-value {
  font-size: var(--font-size-sm);
  color: var(--text-primary);
  font-weight: var(--font-weight-medium);
}

.info-divider {
  height: 1px;
  background: var(--divider-color);
}

/* ============================================   4. 指标详情卡片   ============================================ */
.indicators-card {
  border-radius: 20px;
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-lg);
  box-shadow: var(--shadow-sm);
  border: none;
}

.normal-bg {
  background: var(--success-bg);
}

.warning-bg {
  background: var(--warning-bg);
}

.danger-bg {
  background: var(--danger-bg);
}

.critical-bg {
  background: var(--critical-bg);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-md);
  padding-bottom: var(--spacing-md);
  border-bottom: 1px solid rgba(0, 0, 0, 0.06);
}

.card-title-row {
  display: flex;
  align-items: center;
}

.card-icon {
  font-size: 16px;
  margin-right: var(--spacing-sm);
  font-weight: bold;
}

.card-icon.normal {
  color: var(--success);
}

.card-icon.warning {
  color: var(--warning);
}

.card-icon.danger {
  color: var(--danger);
}

.card-icon.critical {
  color: var(--critical);
}

.card-title-text {
  font-size: var(--font-size-h3);
  font-weight: var(--font-weight-semibold);
  color: var(--text-primary);
}

.level-badge {
  padding: 4px 12px;
  border-radius: var(--radius-full);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-medium);
  border: 1px solid;
}

.level-badge.normal {
  background: var(--success-10);
  color: var(--success);
  border-color: var(--success-20);
}

.level-badge.warning {
  background: var(--warning-10);
  color: var(--warning);
  border-color: var(--warning-20);
}

.level-badge.danger {
  background: var(--danger-10);
  color: var(--danger);
  border-color: var(--danger-20);
}

.level-badge.critical {
  background: var(--critical-10);
  color: var(--critical);
  border-color: var(--critical-20);
}

/* ============================================   5. 指标列表   ============================================ */
.indicators-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-md);
}

/* ============================================   6. 指标项 - 独立卡片样式   ============================================ */
.indicator-item {
  padding: var(--spacing-md);
  border-radius: 12px;
  background: rgba(255, 255, 255, 0.4);
  transition: all var(--transition-base);
}

.indicator-item.abnormal-item {
  background: rgba(255, 255, 255, 0.6);
}

.indicator-info {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.indicator-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.indicator-name {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--text-primary);
}

.indicator-reference {
  font-size: var(--font-size-xs);
  color: var(--text-muted);
}

.indicator-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4px;
}

.indicator-value {
  font-size: 24px;
  font-weight: var(--font-weight-bold);
  font-family: 'SF Mono', 'Monaco', 'Consolas', monospace;
  line-height: 1.2;
}

.indicator-value.normal {
  color: var(--success);
}

.indicator-value.warning {
  color: var(--warning);
}

.indicator-value.danger {
  color: var(--danger);
}

.indicator-value.critical {
  color: var(--critical);
}

.indicator-badge {
  padding: 2px 8px;
  border-radius: var(--radius-full);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-medium);
  border: 1px solid;
}

.indicator-badge.normal {
  background: var(--success-10);
  color: var(--success);
  border-color: var(--success-20);
}

.indicator-badge.warning {
  background: var(--warning-10);
  color: var(--warning);
  border-color: var(--warning-20);
}

.indicator-badge.danger {
  background: var(--danger-10);
  color: var(--danger);
  border-color: var(--danger-20);
}

.indicator-badge.critical {
  background: var(--critical-10);
  color: var(--critical);
  border-color: var(--critical-20);
}

/* ============================================   7. 处理建议区域   ============================================ */
.advice-section {
  margin-top: var(--spacing-sm);
}

.advice-box {
  background: rgba(0, 0, 0, 0.04);
  border-radius: 8px;
  padding: 10px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.advice-label {
  font-size: var(--font-size-xs);
  color: var(--text-muted);
}

.advice-content {
  font-size: var(--font-size-sm);
  color: var(--text-primary);
  line-height: 1.5;
}

.advice-divider {
  height: 1px;
  background: rgba(0, 0, 0, 0.06);
  margin-top: 4px;
  margin-bottom: 4px;
}

.discharge-advice {
  font-size: var(--font-size-sm);
  color: var(--primary-color);
  line-height: 1.6;
}

/* ============================================   8. 参考链接   ============================================ */
.reference-link {
  display: flex;
  align-items: center;
  gap: 4px;
  margin-top: var(--spacing-md);
  padding: var(--spacing-sm) 0;
  transition: opacity var(--transition-base);
}

.reference-link:active {
  opacity: 0.7;
}

.reference-link-icon {
  font-size: 14px;
  color: var(--primary-color);
}

.reference-link-text {
  font-size: var(--font-size-xs);
  color: var(--primary-color);
}

/* ============================================   9. 图例说明   ============================================ */
.legend-badge.normal {
  background: var(--success-10);
  color: var(--success);
  border-color: var(--success-20);
}

.legend-badge.warning {
  background: var(--warning-10);
  color: var(--warning);
  border-color: var(--warning-20);
}

.legend-badge.danger {
  background: var(--danger-10);
  color: var(--danger);
  border-color: var(--danger-20);
}

.legend-badge.critical {
  background: var(--critical-10);
  color: var(--critical);
  border-color: var(--critical-20);
}

.legend-section {
  margin-top: var(--spacing-md);
  padding-top: var(--spacing-md);
  border-top: 1px solid rgba(0, 0, 0, 0.06);
}

.legend-title {
  font-size: var(--font-size-xs);
  color: var(--text-muted);
  margin-bottom: var(--spacing-sm);
  display: block;
}

.legend-badges {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-sm);
}

.legend-badge {
  padding: 2px 8px;
  border-radius: var(--radius-full);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-medium);
  border: 1px solid;
}

/* ============================================   9.1 其他指标模块   ============================================ */
.other-indicators-card {
  background: var(--surface);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-lg);
  box-shadow: var(--shadow-sm);
}

.card-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-title {
  font-size: var(--font-size-h3);
  font-weight: var(--font-weight-semibold);
  color: var(--text-primary);
}

.toggle-icon {
  font-size: var(--font-size-xs);
  color: var(--primary-color);
  padding: 4px 12px;
  background: var(--primary-50);
  border-radius: var(--radius-full);
  white-space: nowrap;
}

.other-indicators-list {
  margin-top: var(--spacing-md);
  padding-top: var(--spacing-md);
  border-top: 1px solid var(--divider-color);
}

.other-indicator-item {
  padding: var(--spacing-sm) 0;
  border-bottom: 1px solid var(--divider-color);
}

.other-indicator-item:last-child {
  border-bottom: none;
}

.other-indicator-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 4px;
}

.other-indicator-name {
  font-size: var(--font-size-sm);
  color: var(--text-primary);
}

.other-indicator-right {
  display: flex;
  align-items: center;
  gap: 8px;
}

.other-indicator-value {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--text-primary);
}

.other-indicator-status {
  font-size: var(--font-size-xs);
  padding: 2px 8px;
  border-radius: var(--radius-full);
}

.other-indicator-status.normal {
  background: var(--success-10);
  color: var(--success);
}

.other-indicator-status.abnormal {
  background: var(--danger-10);
  color: var(--danger);
}

.other-indicator-reference {
  font-size: var(--font-size-xs);
  color: var(--text-muted);
}

/* ============================================   10. 免责声明   ============================================ */
.disclaimer-text {
  font-size: var(--font-size-xs);
  color: var(--text-muted);
  line-height: var(--line-height-relaxed);
}

/* ============================================   11. 悬浮按钮   ============================================ */
.fab-container {
  position: fixed;
  bottom: 24px;
  right: 16px;
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  gap: 20px;
  z-index: 50;
}

.fab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.fab-button {
  width: 52px;
  height: 52px;
  border-radius: 50%;
  background: var(--primary-color);
  box-shadow: 0 8px 20px rgba(20, 184, 166, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform var(--transition-base);
}

.fab-button:active {
  transform: scale(0.95);
}

.fab-icon {
  font-size: 22px;
}

.fab-label {
  margin-top: 4px;
  padding: 2px 10px;
  background: var(--primary-color);
  color: white;
  font-size: var(--font-size-xs);
  border-radius: var(--radius-full);
  box-shadow: var(--shadow-sm);
}