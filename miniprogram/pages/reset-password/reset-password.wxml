<view class="container page-enter">

  <view class="header-section animate-fade-in">
    <text class="header-title">修改密码</text>
    <text class="header-subtitle">通过验证后重置密码</text>
  </view>

  <view class="form-card animate-slide-up" wx:if="{{mode === 'all'}}">
    <view class="verify-method-tabs">
      <view class="method-tab {{verifyMethod === 'password' ? 'active' : ''}}" bindtap="onVerifyMethodChange" data-method="password">
        <text>当前密码验证</text>
      </view>
      <view class="method-tab {{verifyMethod === 'security' ? 'active' : ''}} {{!hasSecurityQuestion ? 'disabled' : ''}}" bindtap="onVerifyMethodChange" data-method="security">
        <text>安全问题验证</text>
      </view>
    </view>
  </view>

  <view class="form-card animate-slide-up" wx:if="{{verifyMethod === 'password' && (mode === 'all' || mode === 'password')}}">
    <view class="input-group">
      <text class="input-label">当前密码</text>
      <view class="password-input-wrapper">
        <input
          class="password-input"
          password="{{!showOldPassword}}"
          placeholder="请输入当前密码"
          value="{{oldPassword}}"
          bindinput="onOldPasswordInput"
        />
        <view class="password-toggle" bindtap="toggleOldPassword">
          <image src="{{showOldPassword ? '/images/icon-eye.svg' : '/images/icon-eye-off.svg'}}" class="toggle-icon"></image>
        </view>
      </view>
    </view>
  </view>

  <view class="form-card animate-slide-up" wx:if="{{verifyMethod === 'security' && (mode === 'all' || mode === 'security')}}">
    <view class="input-group" wx:if="{{hasSecurityQuestion}}">
      <text class="input-label">安全问题</text>
      <view class="question-display">
        <text class="question-text">{{securityQuestionText}}</text>
      </view>
    </view>

    <view class="input-group" wx:if="{{hasSecurityQuestion}}">
      <text class="input-label">您的答案</text>
      <view class="password-input-wrapper">
        <input
          class="password-input"
          password="{{!showSecurityAnswer}}"
          placeholder="请输入安全问题的答案"
          value="{{securityAnswer}}"
          bindinput="onSecurityAnswerInput"
        />
        <view class="password-toggle" bindtap="toggleSecurityAnswer">
          <image src="{{showSecurityAnswer ? '/images/icon-eye.svg' : '/images/icon-eye-off.svg'}}" class="toggle-icon"></image>
        </view>
      </view>
    </view>

    <view class="no-security-hint" wx:if="{{!hasSecurityQuestion}}">
      <image src="/images/icon-warning.svg" class="hint-icon"></image>
      <text class="hint-text">您尚未设置安全问题，无法使用此方式重置密码</text>
    </view>
  </view>

  <view class="form-card animate-slide-up">
    <view class="input-group">
      <text class="input-label">新密码</text>
      <view class="password-input-wrapper">
        <input
          class="password-input"
          password="{{!showNewPassword}}"
          placeholder="至少6位，含数字和字母"
          value="{{newPassword}}"
          bindinput="onNewPasswordInput"
        />
        <view class="password-toggle" bindtap="toggleNewPassword">
          <image src="{{showNewPassword ? '/images/icon-eye.svg' : '/images/icon-eye-off.svg'}}" class="toggle-icon"></image>
        </view>
      </view>
    </view>

    <view class="input-group">
      <text class="input-label">确认新密码</text>
      <view class="password-input-wrapper">
        <input
          class="password-input"
          password="{{!showConfirmPassword}}"
          placeholder="请再次输入新密码"
          value="{{confirmPassword}}"
          bindinput="onConfirmPasswordInput"
        />
        <view class="password-toggle" bindtap="toggleConfirmPassword">
          <image src="{{showConfirmPassword ? '/images/icon-eye.svg' : '/images/icon-eye-off.svg'}}" class="toggle-icon"></image>
        </view>
      </view>
    </view>
  </view>

  <view class="action-section">
    <button
      class="btn-primary btn-press"
      bindtap="handleReset"
      loading="{{isLoading}}"
      disabled="{{isLoading || (verifyMethod === 'security' && !hasSecurityQuestion)}}"
    >
      {{isLoading ? '处理中...' : '确认修改'}}
    </button>
  </view>

</view>
