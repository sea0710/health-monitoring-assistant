<view class="container page-enter">
  <view class="header">
    <text class="title">重置密码</text>
    <text class="subtitle">通过回答安全问题来重置您的密码</text>
  </view>

  <view class="form-section">
    <view class="info-card" wx:if="{{!showResetForm}}">
      <text class="info-text">请输入您的账号标识（OpenID或昵称）来查找账户</text>
    </view>

    <view class="form-item" wx:if="{{!showResetForm}}">
      <text class="form-label">账号标识</text>
      <input 
        type="text"
        placeholder="请输入OpenID或昵称"
        value="{{accountIdentifier}}"
        bindinput="onAccountInput"
        class="form-input"
      />
      <button class="btn-primary btn-block" bindtap="handleFindAccount" loading="{{isFinding}}" disabled="{{!accountIdentifier}}">
        {{isFinding ? '查找中...' : '查找账户'}}
      </button>
    </view>

    <view wx:if="{{showResetForm && foundUser}}">
      <view class="user-info-display">
        <text class="user-label">找到账户：</text>
        <text class="user-value">{{foundUser.nickname || '用户' + foundUser._id.substr(-6)}}</text>
      </view>
      
      <view class="question-display">
        <text class="question-label">安全问题：</text>
        <text class="question-value">{{foundUser.security_question}}</text>
      </view>

      <view class="form-item">
        <text class="form-label">问题答案 <text class="required">*</text></text>
        <input 
          type="text"
          placeholder="请输入答案"
          value="{{answer}}"
          bindinput="onAnswerInput"
          class="form-input"
        />
      </view>

      <view class="form-item">
        <text class="form-label">新密码 <text class="required">*</text></text>
        <input 
          type="password"
          placeholder="请设置新密码（至少6位）"
          value="{{newPassword}}"
          bindinput="onNewPasswordInput"
          class="form-input"
        />
      </view>

      <view class="form-item">
        <text class="form-label">确认新密码 <text class="required">*</text></text>
        <input 
          type="password"
          placeholder="请再次输入新密码"
          value="{{confirmPassword}}"
          bindinput="onConfirmPasswordInput"
          class="form-input"
        />
      </view>

      <button 
        class="btn-primary btn-bottom" 
        bindtap="handleResetPassword" 
        loading="{{isResetting}}"
        disabled="{{!canSubmit}}"
      >
        {{isResetting ? '重置中...' : '确认重置'}}
      </button>
    </view>

    <view class="error-hint" wx:if="{{errorMsg}}">
      <text>{{errorMsg}}</text>
    </view>
  </view>
</view>