.container {
  min-height: 100vh;
  padding: 16px;
  padding-bottom: 100px;
  background: #f8faf9;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 16px;
  border-bottom: 1px solid #e5e7eb;
  margin-bottom: 16px;
}

.back-btn {
  display: flex;
  align-items: center;
  padding: 8px;
  margin-left: -8px;
}

.back-icon {
  font-size: 20px;
  color: #14b8a6;
  margin-right: 4px;
}

.back-text {
  font-size: 14px;
  color: #14b8a6;
}

.title {
  font-size: 18px;
  font-weight: 600;
  color: #1f2937;
}

.placeholder {
  width: 60px;
}

.indicator-selector {
  margin-bottom: 16px;
}

.selector-scroll {
  width: 100%;
  white-space: nowrap;
}

.selector-list {
  display: inline-flex;
  gap: 8px;
}

.selector-item {
  display: inline-flex;
  padding: 8px 16px;
  background: #ffffff;
  border: 1px solid #e5e7eb;
  border-radius: 20px;
  font-size: 14px;
  color: #6b7280;
}

.selector-item.active {
  background: #14b8a6;
  border-color: #14b8a6;
  color: #ffffff;
}

.chart-section {
  background: #ffffff;
  border-radius: 16px;
  padding: 16px;
  margin-bottom: 16px;
}

.chart-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}

.chart-title {
  font-size: 16px;
  font-weight: 600;
  color: #1f2937;
}

.chart-period {
  font-size: 12px;
  color: #9ca3af;
}

.chart-container {
  width: 100%;
  height: 250px;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48px 0;
  background: #ffffff;
  border-radius: 16px;
  margin-bottom: 16px;
}

.empty-icon {
  width: 48px;
  height: 48px;
  margin-bottom: 12px;
  opacity: 0.4;
}

.empty-title {
  font-size: 14px;
  color: #6b7280;
  margin-bottom: 4px;
}

.empty-desc {
  font-size: 12px;
  color: #9ca3af;
}

.data-table {
  background: #ffffff;
  border-radius: 16px;
  padding: 16px;
  margin-bottom: 16px;
}

.table-title {
  font-size: 14px;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 12px;
  display: block;
}

.table-header {
  display: flex;
  padding: 12px 0;
  border-bottom: 1px solid #e5e7eb;
}

.table-row {
  display: flex;
  padding: 12px 0;
  border-bottom: 1px solid #f3f4f6;
}

.table-row:last-child {
  border-bottom: none;
}

.table-cell {
  flex: 1;
  font-size: 14px;
  color: #374151;
}

.table-header .table-cell {
  font-weight: 500;
  color: #6b7280;
}

.status-dot {
  display: inline-block;
  width: 8px;
  height: 8px;
  border-radius: 50%;
}

.status-dot.normal {
  background: #22c55e;
}

.status-dot.abnormal {
  background: #f59e0b;
}

.disclaimer {
  padding: 16px 0;
  text-align: center;
}

.disclaimer-text {
  font-size: 12px;
  color: #9ca3af;
  line-height: 1.6;
}
