<view class="container page-enter">

  <!-- 未登录引导 -->
  <view class="guest-guide" wx:if="{{!hasLogin}}">
    <text class="guest-icon icon icon-xl">📊</text>
    <text class="guest-title">趋势分析</text>
    <text class="guest-desc">登录后可查看您的血常规指标变化趋势</text>
    <button class="btn-guide btn-press" bindtap="handleGuideLogin">
      开始使用
    </button>
  </view>

  <!-- 已登录内容 -->
  <block wx:if="{{hasLogin}}">
  <view class="indicator-selector">
    <scroll-view scroll-x class="selector-scroll">
      <view class="selector-list">
        <view 
          class="selector-item {{currentIndicator === item.code ? 'active' : ''}}" 
          wx:for="{{indicatorOptions}}" 
          wx:key="code"
          bindtap="handleIndicatorChange"
          data-code="{{item.code}}"
        >
          <text>{{item.name}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="chart-section" wx:if="{{chartData.length > 0}}">
    <view class="chart-info">
      <text class="chart-title">{{currentIndicatorName}}趋势</text>
      <text class="chart-period">近{{chartData.length}}次检测</text>
    </view>
    
    <view class="chart-container">
      <ec-canvas id="mychart-dom-bar" canvas-id="mychart-bar" ec="{{ ec }}"></ec-canvas>
    </view>
  </view>

  <view class="empty-state" wx:else>
    <text class="empty-title">暂无趋势数据</text>
    <text class="empty-desc">上传更多报告后可查看趋势图</text>
    <button class="btn-upload btn-press" bindtap="goToUpload">上传报告</button>
  </view>

  <view class="data-table" wx:if="{{chartData.length > 0}}">
    <text class="table-title">历史数据</text>
    
    <view class="table-header">
      <text class="table-cell">日期</text>
      <text class="table-cell">数值</text>
      <text class="table-cell">状态</text>
    </view>
    
    <view class="table-row" wx:for="{{chartData}}" wx:key="date">
      <text class="table-cell">{{item.date}}</text>
      <text class="table-cell">{{item.value}}</text>
      <text class="table-cell">
        <text class="status-text {{item.level}}">{{item.levelText}}</text>
      </text>
    </view>
  </view>
  </block>

  <view class="disclaimer">
    <text class="disclaimer-text">本工具仅供内部测试与健康科普参考，不构成任何诊疗建议，不能替代执业医师的专业判断</text>
  </view>
</view>