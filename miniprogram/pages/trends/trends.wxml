<view class="container">
  <view class="header">
    <view class="back-btn" bindtap="handleBack">
      <text class="back-icon">‹</text>
      <text class="back-text">返回</text>
    </view>
    <text class="title">指标趋势</text>
    <view class="placeholder"></view>
  </view>

  <view class="indicator-selector">
    <scroll-view scroll-x class="selector-scroll">
      <view class="selector-list">
        <view 
          class="selector-item {{currentIndicator === item.code ? 'active' : ''}}" 
          wx:for="{{indicatorOptions}}" 
          wx:key="code"
          bindtap="handleIndicatorChange"
          data-code="{{item.code}}"
        >
          <text>{{item.name}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="chart-section" wx:if="{{trendData.length > 0}}">
    <view class="chart-info">
      <text class="chart-title">{{currentIndicatorName}}趋势</text>
      <text class="chart-period">近{{trendData.length}}次检测</text>
    </view>
    
    <view class="chart-container">
      <ec-canvas id="mychart-dom-bar" canvas-id="mychart-bar" ec="{{ ec }}"></ec-canvas>
    </view>
  </view>

  <view class="empty-state" wx:else>
    <image src="/images/icon-chart-empty.svg" class="empty-icon"></image>
    <text class="empty-title">暂无趋势数据</text>
    <text class="empty-desc">上传更多报告后可查看趋势图</text>
  </view>

  <view class="data-table" wx:if="{{trendData.length > 0}}">
    <text class="table-title">历史数据</text>
    
    <view class="table-header">
      <text class="table-cell">日期</text>
      <text class="table-cell">数值</text>
      <text class="table-cell">状态</text>
    </view>
    
    <view class="table-row" wx:for="{{trendData}}" wx:key="date">
      <text class="table-cell">{{item.date}}</text>
      <text class="table-cell">{{item[currentIndicator] || '-'}}</text>
      <text class="table-cell">
        <text class="status-dot {{item.isAbnormal ? 'abnormal' : 'normal'}}"></text>
      </text>
    </view>
  </view>

  <view class="disclaimer">
    <text class="disclaimer-text">本工具仅供内部测试与健康科普参考，不构成任何诊疗建议</text>
  </view>
</view>
