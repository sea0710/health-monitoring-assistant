<view class="container page-enter">

  <view class="header-section animate-fade-in">
    <text class="header-title">设置登录密码</text>
    <text class="header-subtitle">设置密码后，需要在登录时输入正确密码</text>
  </view>

  <view class="form-card animate-slide-up">
    <view class="input-group">
      <text class="input-label">密码</text>
      <view class="password-input-wrapper">
        <input
          class="input-field password-input input-glow"
          password="{{!showPassword}}"
          placeholder="至少6位，含数字和字母"
          value="{{password}}"
          bindinput="onPasswordInput"
        />
        <view class="password-toggle btn-press" bindtap="togglePassword">
          <image src="{{showPassword ? '/images/icon-eye.svg' : '/images/icon-eye-off.svg'}}" class="toggle-icon"></image>
        </view>
      </view>
    </view>

    <view class="input-group">
      <text class="input-label">确认密码</text>
      <view class="password-input-wrapper">
        <input
          class="input-field password-input input-glow"
          password="{{!showConfirmPassword}}"
          placeholder="请再次输入密码"
          value="{{confirmPassword}}"
          bindinput="onConfirmPasswordInput"
        />
        <view class="password-toggle btn-press" bindtap="toggleConfirmPassword">
          <image src="{{showConfirmPassword ? '/images/icon-eye.svg' : '/images/icon-eye-off.svg'}}" class="toggle-icon"></image>
        </view>
      </view>
    </view>
  </view>

  <view class="section-label animate-fade-in">
    <text class="section-title">安全问题（必填，用于找回密码）</text>
    <text class="section-desc">忘记密码时，可通过回答安全问题重置密码</text>
  </view>

  <view class="form-card animate-slide-up">
    <view class="input-group">
      <text class="input-label">选择安全问题</text>
      <picker mode="selector" range="{{questionList}}" range-key="question" value="{{questionIndex}}" bindchange="onQuestionChange">
        <view class="picker-field {{questionIndex >= 0 ? '' : 'picker-placeholder'}}">
          <text>{{questionIndex >= 0 ? questionList[questionIndex].question : '请选择安全问题'}}</text>
          <image src="/images/icon-book.svg" class="picker-arrow"></image>
        </view>
      </picker>
    </view>

    <view class="input-group" wx:if="{{questionIndex >= 0}}">
      <text class="input-label">答案</text>
      <view class="password-input-wrapper">
        <input
          class="input-field password-input input-glow"
          password="{{!showAnswer}}"
          placeholder="{{questionIndex >= 0 ? questionList[questionIndex].hint : '请输入答案'}}"
          value="{{securityAnswer}}"
          bindinput="onAnswerInput"
        />
        <view class="password-toggle btn-press" bindtap="toggleAnswer">
          <image src="{{showAnswer ? '/images/icon-eye.svg' : '/images/icon-eye-off.svg'}}" class="toggle-icon"></image>
        </view>
      </view>
    </view>
  </view>

  <view class="action-section">
    <button class="btn-primary btn-press" bindtap="handleConfirm" loading="{{isLoading}}" disabled="{{isLoading}}">
      {{isLoading ? '设置中...' : '确认设置'}}
    </button>
  </view>

</view>
