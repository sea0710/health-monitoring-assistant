<view class="container page-enter">
  <view class="header">
    <text class="title">设置登录密码</text>
    <text class="subtitle">设置密码后可通过密码+安全问题找回账户</text>
  </view>

  <view class="form-section">
    <view class="form-item">
      <text class="form-label">新密码 <text class="required">*</text></text>
      <input 
        type="password"
        placeholder="请设置密码（至少6位）"
        value="{{newPassword}}"
        bindinput="onNewPasswordInput"
        class="form-input"
      />
    </view>

    <view class="form-item">
      <text class="form-label">确认新密码 <text class="required">*</text></text>
      <input 
        type="password"
        placeholder="请再次输入新密码"
        value="{{confirmPassword}}"
        bindinput="onConfirmPasswordInput"
        class="form-input"
      />
    </view>
  </view>

  <view class="security-section">
    <text class="section-title">安全问题（用于找回密码）</text>
    <text class="section-hint">选择一个问题并设置答案，忘记密码时可用于验证身份</text>

    <picker mode="selector" range="{{questionList}}" range-key="question" bindchange="onQuestionChange">
      <view class="picker-field {{selectedQuestion ? '' : 'placeholder'}}">
        {{selectedQuestion ? selectedQuestion.question : '请选择一个安全问题'}}
      </view>
    </picker>

    <view class="answer-hint" wx:if="{{selectedQuestion}}">
      <text>提示：{{selectedQuestion.hint}}</text>
    </view>

    <input 
      type="text"
      placeholder="请输入答案"
      value="{{answer}}"
      bindinput="onAnswerInput"
      class="form-input"
      wx:if="{{selectedQuestion}}"
    />
  </view>

  <button 
    class="btn-primary btn-bottom" 
    bindtap="handleSetPassword" 
    loading="{{isSetting}}"
    disabled="{{!canSubmit}}"
  >
    {{isSetting ? '设置中...' : '确认设置'}}
  </button>
</view>