<view class="container page-enter">

  <view class="quick-actions">
    <view class="action-card card-interactive" bindtap="handleQuickAccess" data-path="/pages/reference/reference">
      <view class="action-icon-wrapper action-icon-primary">
        <text class="action-icon-text icon icon-lg">📖</text>
      </view>
      <view class="action-content">
        <text class="action-title">分级速查</text>
        <text class="action-desc">WHO分级标准</text>
      </view>
    </view>
    <view class="action-card card-interactive" bindtap="handleQuickAccess" data-path="/pages/reminder/reminder">
      <view class="action-icon-wrapper action-icon-warning">
        <text class="action-icon-text icon icon-lg">🔔</text>
      </view>
      <view class="action-content">
        <text class="action-title">提醒设置</text>
        <text class="action-desc">复查提醒管理</text>
      </view>
    </view>
  </view>

  <view class="patient-card card-interactive" bindtap="handlePatientEdit">
    <view class="patient-info">
      <view class="patient-main">
        <text class="patient-label">患者姓名</text>
        <text class="patient-name">{{patient.name || '未知患者'}}</text>
      </view>
      <view class="patient-stats">
        <text class="stats-label">报告总数</text>
        <text class="stats-value">{{reports.length}}</text>
      </view>
    </view>
    <view class="patient-meta">
      <view class="meta-row">
        <text>最近检测：{{latestReport.test_time || '暂无记录'}}</text>
      </view>
      <view class="meta-row" wx:if="{{nextReminder}}">
        <text class="bell-icon icon icon-sm">🔔</text>
        <text>下次提醒：{{nextReminder}}</text>
      </view>
    </view>
  </view>

  <view class="reports-section">
    <view class="section-header-row">
      <text class="section-title">历史报告</text>
      <view class="add-btn-small btn-press" bindtap="handleAddReport">
        <text class="add-icon-small icon icon-sm">+</text>
        <text class="add-text-small">添加</text>
      </view>
    </view>
    
    <view class="reports-content-wrapper">
      <!-- 骨架屏 -->
      <view class="skeleton-container" wx:if="{{isFirstLoading}}">
        <view class="skeleton-card" wx:for="{{3}}" wx:key="index">
          <view class="skeleton-header">
            <view class="skeleton-tag"></view>
            <view class="skeleton-date"></view>
          </view>
          <view class="skeleton-content">
            <view class="skeleton-badge"></view>
          </view>
        </view>
      </view>
      
      <!-- 报告列表 -->
      <view class="reports-list" wx:elif="{{reports.length > 0}}">
        <view 
          class="report-item list-item-enter" 
          wx:for="{{displayReports}}" 
          wx:key="_id"
          style="animation-delay: {{(index) * 0.05}}s"
        >
          <view class="report-item-content card-interactive" bindtap="handleReportClick" data-id="{{item._id}}">
            <view class="report-header">
              <view class="report-tags">
                <text class="report-type">{{item.report_type || '血常规'}}</text>
                <text class="report-date">{{item.test_time}}</text>
              </view>
            </view>
            <view class="report-content">
              <view class="report-badge {{item.abnormal_count > 0 ? 'badge-warning' : 'badge-success'}}">
                <text>{{item.abnormal_count > 0 ? item.abnormal_count + '项异常' : '指标正常'}}</text>
              </view>
            </view>
          </view>
          <view class="report-delete btn-press" bindtap="handleDeleteReport" data-id="{{item._id}}">
            <text class="delete-icon icon icon-sm">×</text>
          </view>
          <view class="report-arrow">
            <text class="arrow-icon icon icon-sm">></text>
          </view>
        </view>
        
        <view class="expand-btn btn-press" wx:if="{{reports.length > 5}}" bindtap="toggleReportsExpand">
          <text>{{reportsExpanded ? '收起' : '查看更多 (' + (reports.length - 5) + '条)'}}</text>
        </view>
      </view>

      <!-- 空状态 -->
      <view class="empty-state" wx:else>
        <text class="empty-icon icon icon-xl floating">📄</text>
        <text class="empty-title">暂无报告</text>
        <text class="empty-desc">点击右上角添加第一份报告</text>
      </view>
      
      <!-- 加载动画 - 只在历史报告区域显示 -->
      <view class="loading-overlay-local" wx:if="{{isLoading && !isFirstLoading}}">
        <view class="loading-spinner-local loading-spin"></view>
        <text class="loading-text-local">加载中...</text>
      </view>
    </view>
  </view>

  <view class="disclaimer">
    <text class="disclaimer-text">本工具仅供内部测试与健康科普参考，不构成任何诊疗建议，不能替代执业医师的专业判断</text>
  </view>
</view>