<view class="container page-enter">
  <!-- 未登录引导 -->
  <view class="login-guide-card" wx:if="{{!hasLogin}}">
    <view class="login-guide-bg"></view>
    <view class="login-guide-content">
      <view class="guide-avatar-wrap">
        <image src="/images/default-avatar.svg" mode="aspectFill" class="guide-avatar-img"></image>
      </view>
      <text class="guide-title">欢迎使用愈见</text>
      <text class="guide-desc">登录后可查看或记录您的数据，设置提醒等</text>
      <view class="btn-primary btn-press guide-login-btn" bindtap="handleLogin">微信一键登录</view>
      <!-- 协议勾选区域 -->
      <view class="agreement-area">
        <view class="agreement-checkbox" bindtap="toggleAgreement">
          <view class="checkbox-icon {{agreedToTerms ? 'checked' : ''}}">
            <view class="check-mark" wx:if="{{agreedToTerms}}"></view>
          </view>
        </view>
        <view class="agreement-text-wrap">
          <text class="agreement-text">我已阅读并同意</text>
          <text class="agreement-link" bindtap="goToAgreement" data-tab="terms">《用户服务协议》</text>
          <text class="agreement-text">及</text>
          <text class="agreement-link" bindtap="goToAgreement" data-tab="privacy">《隐私政策》</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 已登录内容 -->
  <block wx:if="{{hasLogin}}">
    <view class="patient-card" bindtap="goToProfile">
      <view class="patient-card-bg"></view>
      <view class="patient-card-content">
        <view class="patient-top-row">
          <view class="patient-user-section">
            <view class="patient-avatar-wrap">
              <image src="{{userAvatar || '/images/default-avatar.svg'}}" mode="aspectFill" class="patient-avatar-img"></image>
              <view class="avatar-setting-hint" wx:if="{{!userAvatar || !userNickname}}">
                <text class="hint-dot"></text>
              </view>
            </view>
            <view class="patient-user-info">
              <text class="patient-nickname">{{userNickname || '点击设置昵称'}}</text>
              <view class="patient-name-row" wx:if="{{!patient}}">
                <text class="patient-name-label">未创建患者</text>
              </view>
            </view>
          </view>
          <view class="patient-settings-entry">
            <image src="/images/icon-settings.svg" class="settings-icon-img"></image>
          </view>
        </view>
        <view class="patient-stats-row">
          <view class="stat-item stat-item-patient" wx:if="{{patient}}">
            <text class="stat-value stat-patient-name">{{patient.name}}</text>
            <text class="stat-label">患者</text>
          </view>
          <view class="stat-divider" wx:if="{{patient}}"></view>
          <view class="stat-item">
            <text class="stat-value">{{reports.length}}</text>
            <text class="stat-label">报告数</text>
          </view>
          <view class="stat-divider"></view>
          <view class="stat-item" wx:if="{{latestReport}}">
            <text class="stat-value stat-value-sm">{{latestReport.test_time}}</text>
            <text class="stat-label">最近检测</text>
          </view>
          <view class="stat-item" wx:else>
            <text class="stat-value stat-value-sm">--</text>
            <text class="stat-label">最近检测</text>
          </view>
        </view>
        <view class="patient-guide-tip" wx:if="{{!userAvatar || !userNickname}}">
          <text class="guide-tip-text">点击完善个人信息，获得更好体验</text>
        </view>
      </view>
    </view>

    <view class="reports-section">
      <view class="section-header-row">
        <text class="section-title">历史报告</text>
        <view class="add-btn-small btn-press" bindtap="handleAddReport">
          <text class="add-icon-small icon icon-sm">+</text>
          <text class="add-text-small">添加</text>
        </view>
      </view>

      <view class="reports-content-wrapper">
        <view class="skeleton-container" wx:if="{{isFirstLoading}}">
          <view class="skeleton-card" wx:for="{{3}}" wx:key="index">
            <view class="skeleton-header">
              <view class="skeleton-tag"></view>
              <view class="skeleton-date"></view>
            </view>
            <view class="skeleton-content">
              <view class="skeleton-badge"></view>
            </view>
          </view>
        </view>

        <view class="reports-list" wx:elif="{{reports.length > 0}}">
          <view
            class="report-item list-item-enter"
            wx:for="{{displayReports}}"
            wx:key="_id"
            style="animation-delay: {{(index) * 0.05}}s"
          >
            <view class="report-item-content card-interactive" bindtap="handleReportClick" data-id="{{item._id}}">
              <view class="report-header">
                <view class="report-tags">
                  <text class="report-type">{{item.report_type || '血常规'}}</text>
                  <text class="report-date">{{item.test_time}}</text>
                </view>
              </view>
              <view class="report-content">
                <view class="report-badge {{item.abnormal_count > 0 ? 'badge-warning' : 'badge-success'}}">
                  <text>{{item.abnormal_count > 0 ? item.abnormal_count + '项异常' : '指标正常'}}</text>
                </view>
              </view>
            </view>
            <view class="report-delete btn-press" bindtap="handleDeleteReport" data-id="{{item._id}}">
              <text class="delete-icon icon icon-sm">×</text>
            </view>
            <view class="report-arrow">
              <text class="arrow-icon icon icon-sm">></text>
            </view>
          </view>

          <view class="expand-btn btn-press" wx:if="{{reports.length > 5}}" bindtap="toggleReportsExpand">
            <text>{{reportsExpanded ? '收起' : '查看更多 (' + (reports.length - 5) + '条)'}}</text>
          </view>
        </view>

        <view class="empty-state" wx:elif="{{!patient}}">
          <image src="/images/icon-patient-empty.svg" class="empty-state-icon"></image>
          <text class="empty-title">创建患者档案</text>
          <text class="empty-desc">添加患者信息</text>
        </view>

        <view class="empty-state" wx:else>
          <image src="/images/icon-report-empty.svg" class="empty-state-icon"></image>
          <text class="empty-title">暂无报告</text>
          <text class="empty-desc">点击上方添加按钮上传第一份报告</text>
        </view>

        <view class="loading-overlay-local" wx:if="{{isLoading && !isFirstLoading}}">
          <view class="loading-spinner-local loading-spin"></view>
          <text class="loading-text-local">加载中...</text>
        </view>
      </view>
    </view>
  </block>

  <view class="disclaimer disclaimer-tabbar">
    <text class="disclaimer-text">本工具仅供内部测试与健康科普参考，不构成任何诊疗建议，不能替代执业医师的专业判断</text>
  </view>

  <view class="password-modal-mask" wx:if="{{showPasswordModal}}" catchtap="handlePasswordModalCancel">
    <view class="password-modal-content" catchtap>
      <view class="password-modal-header">
        <text class="password-modal-title">请输入登录密码</text>
      </view>
      <view class="password-modal-body">
        <view class="password-modal-input-wrap">
          <input
            class="password-modal-input"
            password="{{!passwordModalVisible}}"
            placeholder="请输入密码"
            value="{{passwordModalValue}}"
            bindinput="onPasswordModalInput"
            bindconfirm="handlePasswordModalConfirm"
            focus="{{showPasswordModal}}"
          />
          <view class="password-modal-eye" bindtap="togglePasswordModalVisible">
            <image src="{{passwordModalVisible ? '/images/icon-eye.svg' : '/images/icon-eye-off.svg'}}" class="password-modal-eye-img"></image>
          </view>
        </view>
        <view class="password-modal-error" wx:if="{{passwordModalError}}">
          <text class="password-modal-error-text">{{passwordModalError}}</text>
        </view>
      </view>
      <view class="password-modal-footer">
        <view class="password-modal-btn password-modal-btn-cancel" bindtap="handlePasswordModalForgot">忘记密码</view>
        <view class="password-modal-btn password-modal-btn-confirm" bindtap="handlePasswordModalConfirm">确认</view>
      </view>
    </view>
  </view>
</view>