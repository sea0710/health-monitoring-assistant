/* ============================================
   首页 - 视觉优化样式
   设计原则：温暖、可靠、简洁
   特点：信息展示页面，需要清晰的信息层级
   ============================================ */

/* ============================================
   1. 页面容器
   ============================================ */
.container {
  min-height: 100vh;
  padding: var(--spacing-lg);
  padding-bottom: 0;
  background: var(--background);
  display: flex;
  flex-direction: column;
}

/* ============================================
   2. 历史报告标题行
   ============================================ */
.section-header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-md);
}

.section-title {
  font-size: var(--font-size-h3);
  font-weight: var(--font-weight-medium);
  color: var(--text-primary);
}

.add-btn-small {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 8px 18px;
  border: 1.5px solid var(--primary-200);
  border-radius: var(--radius-full);
  background: var(--surface);
  transition: all 0.2s ease;
}

.add-btn-small:active {
  background: var(--primary-50);
  transform: scale(0.96);
}

.add-icon-small {
  font-size: 18px;
  color: var(--primary-color);
  font-weight: 600;
  line-height: 1;
}

.add-text-small {
  font-size: 12px;
  color: var(--primary-color);
  font-weight: 600;
}
.quick-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--spacing-md);
  margin-bottom: var(--spacing-lg);
}

.action-card {
  background: var(--surface);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-base);
}

.action-card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-md);
}

.action-icon-wrapper {
  width: 32px;
  height: 32px;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.action-icon-primary {
  background: var(--primary-50);
}

.action-icon-warning {
  background: var(--warning-bg);
}

.action-icon-text {
  font-size: 16px;
}

.action-content {
  flex: 1;
  min-width: 0;
}

.action-title {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
  color: var(--text-primary);
  display: block;
  margin-bottom: 2px;
}

.action-desc {
  font-size: var(--font-size-xs);
  color: var(--text-muted);
  display: block;
}

/* ============================================
   6. 患者信息卡片
   ============================================ */
.patient-card {
  position: relative;
  border-radius: var(--radius-xl);
  margin-bottom: var(--spacing-lg);
  overflow: hidden;
}

.patient-card-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--primary-50);
  z-index: 0;
}

.patient-card-content {
  position: relative;
  z-index: 1;
  padding: 20px;
}

.patient-card:active {
  opacity: 0.95;
  transform: scale(0.99);
  transition: all 0.15s ease;
}

.patient-top-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 16px;
}

.patient-user-section {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.patient-avatar-wrap {
  position: relative;
  width: 52px;
  height: 52px;
  flex-shrink: 0;
}

.patient-avatar-img {
  width: 52px;
  height: 52px;
  border-radius: 50%;
  border: 2px solid rgba(255, 255, 255, 0.4);
  background: rgba(255, 255, 255, 0.15);
}

.avatar-setting-hint {
  position: absolute;
  top: -2px;
  right: -2px;
  width: 14px;
  height: 14px;
  background: #f59e0b;
  border-radius: 50%;
  border: 2px solid #0d9488;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hint-dot {
  width: 4px;
  height: 4px;
  background: #ffffff;
  border-radius: 50%;
}

.patient-user-info {
  flex: 1;
  margin-left: 12px;
  min-width: 0;
}

.patient-nickname {
  font-size: 18px;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 4px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.patient-name-row {
  display: flex;
  align-items: center;
  gap: 6px;
}

.patient-name-label {
  font-size: 12px;
  color: var(--text-secondary);
  background: rgba(20, 184, 166, 0.1);
  padding: 1px 8px;
  border-radius: 10px;
}

.patient-name-value {
  font-size: 14px;
  color: var(--text-primary);
  font-weight: 500;
}

.patient-settings-entry {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(20, 184, 166, 0.1);
  border-radius: 50%;
  flex-shrink: 0;
}

.settings-icon {
  font-size: 18px;
  color: var(--primary-color);
}

.settings-icon-img {
  width: 20px;
  height: 20px;
}

.patient-stats-row {
  display: flex;
  align-items: center;
  background: rgba(20, 184, 166, 0.08);
  border-radius: var(--radius-md);
  padding: 12px 16px;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 0;
}

.stat-item-patient {
  min-width: 60px;
}

.stat-patient-name {
  font-size: 14px;
  font-weight: 600;
}

.stat-value {
  font-size: 16px;
  font-weight: 700;
  font-family: 'SF Mono', 'Monaco', 'Consolas', monospace;
  color: var(--text-primary);
  margin-bottom: 2px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

.stat-value-sm {
  font-size: 12px;
  font-weight: 600;
}

.stat-label {
  font-size: 12px;
  color: var(--text-secondary);
}

.stat-divider {
  width: 1px;
  height: 24px;
  background: rgba(20, 184, 166, 0.2);
  flex-shrink: 0;
}

.patient-guide-tip {
  margin-top: 12px;
  padding: 8px 12px;
  background: rgba(20, 184, 166, 0.1);
  border-radius: var(--radius-sm);
  text-align: center;
}

.guide-tip-text {
  font-size: 12px;
  color: var(--text-secondary);
}

/* ============================================
   7. 报告列表区域
   ============================================ */
.reports-section {
  margin-bottom: var(--spacing-lg);
}

.section-title {
  font-size: var(--font-size-h3);
  font-weight: var(--font-weight-semibold);
  color: var(--text-primary);
  display: block;
  margin-bottom: var(--spacing-md);
}

.reports-content-wrapper {
  position: relative;
  min-height: 200px;
}

/* ============================================
   8. 骨架屏
   ============================================ */
.skeleton-container {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-md);
}

.skeleton-card {
  background: var(--surface);
  border-radius: var(--radius-md);
  padding: var(--spacing-lg);
}

.skeleton-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: var(--spacing-md);
}

.skeleton-tag {
  width: 60px;
  height: 20px;
  background: var(--hover);
  border-radius: var(--radius-sm);
  animation: skeleton-pulse 1.5s ease-in-out infinite;
}

.skeleton-date {
  width: 80px;
  height: 20px;
  background: var(--hover);
  border-radius: var(--radius-sm);
  animation: skeleton-pulse 1.5s ease-in-out infinite;
}

.skeleton-content {
  display: flex;
  align-items: center;
}

.skeleton-badge {
  width: 100px;
  height: 24px;
  background: var(--hover);
  border-radius: var(--radius-sm);
  animation: skeleton-pulse 1.5s ease-in-out infinite;
}

@keyframes skeleton-pulse {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.5;
  }
}

/* ============================================
   9. 报告列表
   ============================================ */
.reports-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
}

.report-item {
  background: var(--surface);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
  display: flex;
  align-items: center;
  transition: all var(--transition-base);
}

.report-item:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-md);
}

.report-item-content {
  flex: 1;
  padding: var(--spacing-lg);
  min-width: 0;
}

.report-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-sm);
}

.report-tags {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
}

.report-type {
  font-size: var(--font-size-xs);
  color: var(--text-muted);
  background: var(--hover);
  padding: 2px 8px;
  border-radius: var(--radius-sm);
}

.report-date {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
  font-weight: var(--font-weight-medium);
}

.report-content {
  display: flex;
  align-items: center;
}

.report-badge {
  display: inline-flex;
  align-items: center;
  padding: 4px 12px;
  border-radius: var(--radius-full);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-medium);
}

.badge-success {
  background: var(--success-bg);
  color: var(--success);
}

.badge-warning {
  background: var(--warning-bg);
  color: var(--warning);
}

.badge-danger {
  background: var(--danger-bg);
  color: var(--danger);
}

.badge-critical {
  background: var(--critical-bg);
  color: var(--critical);
}

.report-delete {
  padding: var(--spacing-md);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background var(--transition-fast);
}

.report-delete:active {
  background: var(--danger-bg);
}

.delete-icon {
  font-size: 20px;
  color: var(--text-muted);
  font-weight: var(--font-weight-regular);
}

.report-arrow {
  padding: var(--spacing-md);
  padding-left: 0;
  display: flex;
  align-items: center;
}

.arrow-icon {
  font-size: 16px;
  color: var(--text-muted);
}

/* ============================================
   10. 展开/收起按钮
   ============================================ */
.expand-btn {
  text-align: center;
  padding: var(--spacing-md) 0;
  font-size: var(--font-size-sm);
  color: var(--primary-color);
  font-weight: var(--font-weight-medium);
  border-top: 1px solid var(--divider-color);
  cursor: pointer;
  transition: all var(--transition-base);
}

.expand-btn:active {
  background: var(--hover);
}

/* ============================================
   11. 空状态
   ============================================ */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48px var(--spacing-lg);
  background: var(--surface);
  border-radius: var(--radius-lg);
}

.empty-state-icon {
  width: 64px;
  height: 64px;
  margin-bottom: var(--spacing-lg);
}

.empty-icon {
  font-size: 48px;
  margin-bottom: var(--spacing-lg);
  opacity: 0.4;
}

.empty-title {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
  margin-bottom: var(--spacing-xs);
  display: block;
}

.empty-desc {
  font-size: var(--font-size-xs);
  color: var(--text-muted);
  display: block;
}

/* ============================================
   患者更新提示卡片
   ============================================ */
.patient-update-hint {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 16px 20px;
  background: var(--surface);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  margin-top: var(--spacing-md);
  transition: all var(--transition-base);
}

.patient-update-hint:active {
  background: var(--hover);
  transform: scale(0.98);
}

.hint-edit-icon {
  width: 24px;
  height: 24px;
  flex-shrink: 0;
  opacity: 0.6;
}

.hint-text-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.hint-main-text {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
  color: var(--text-primary);
  display: block;
}

.hint-sub-text {
  font-size: var(--font-size-xs);
  color: var(--text-muted);
  display: block;
}

.hint-arrow {
  font-size: 20px;
  color: var(--text-muted);
  flex-shrink: 0;
}

/* ============================================
   12. 免责声明
   ============================================ */
.disclaimer-text {
  font-size: var(--font-size-xs);
  color: var(--text-muted);
  line-height: var(--line-height-relaxed);
}

.login-guide-card {
  position: relative;
  border-radius: var(--radius-xl);
  overflow: hidden;
  margin-bottom: var(--spacing-lg);
}

.login-guide-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--primary-50);
  z-index: 0;
}

.login-guide-content {
  position: relative;
  z-index: 1;
  padding: 28px 20px;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.guide-avatar-wrap {
  width: 72px;
  height: 72px;
  border-radius: 50%;
  border: 3px solid rgba(255, 255, 255, 0.4);
  overflow: hidden;
  margin-bottom: 16px;
  background: rgba(255, 255, 255, 0.15);
}

.guide-avatar-img {
  width: 72px;
  height: 72px;
  border-radius: 50%;
}

.login-guide-card .guide-title {
  font-size: 20px;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8px;
}

.login-guide-card .guide-desc {
  font-size: 14px;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 24px;
  line-height: 1.5;
}

.guide-login-btn {
  width: 220px;
  height: 48px;
  margin: 0 auto 12px;
  font-size: 16px;
  background: var(--primary-color);
  color: var(--primary-foreground, #ffffff);
  border-radius: 24px;
}

.guide-login-btn:active {
  background: var(--primary-dark);
  transform: scale(0.97);
}

.login-guide-card .guide-hint {
  font-size: 12px;
  color: var(--text-muted);
  display: block;
}

.patient-avatar {
  display: none;
}

.patient-text {
  display: none;
}

.patient-sub {
  display: none;
}

.patient-arrow {
  display: none;
}

.meta-text {
  display: none;
}

/* ============================================
   协议勾选区域
   ============================================ */
.agreement-area {
  margin-top: 12px;
  padding: 0 4px;
  display: flex;
  align-items: flex-start;
  gap: 6px;
}

.agreement-checkbox {
  flex-shrink: 0;
  padding: 2px;
  margin-top: -1px;
}

.checkbox-icon {
  width: 15px;
  height: 15px;
  border-radius: 3px;
  border: 1.5px solid var(--primary-color);
  position: relative;
  transition: all 0.2s;
  background: rgba(255, 255, 255, 0.9);
}

.checkbox-icon.checked {
  background: var(--primary-color);
  border-color: var(--primary-color);
}

.check-mark {
  position: absolute;
  top: 2px;
  left: 4px;
  width: 4px;
  height: 7px;
  border: solid #ffffff;
  border-width: 0 1.5px 1.5px 0;
  transform: rotate(45deg);
}

.agreement-text-wrap {
  display: flex;
  align-items: center;
  line-height: 18px;
  max-width: 100%;
  width: 100%;
  white-space: nowrap;
}

.agreement-text {
  font-size: 12px;
  color: var(--text-secondary);
}

.agreement-link {
  font-size: 12px;
  color: var(--primary-color);
  font-weight: 500;
}

.password-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.password-modal-content {
  width: 300px;
  background: var(--surface, #ffffff);
  border-radius: 16px;
  overflow: hidden;
}

.password-modal-header {
  padding: 24px 24px 12px;
  text-align: center;
}

.password-modal-title {
  font-size: 17px;
  font-weight: 600;
  color: var(--text-primary);
}

.password-modal-body {
  padding: 8px 24px 16px;
}

.password-modal-input-wrap {
  position: relative;
  display: flex;
  align-items: center;
}

.password-modal-input {
  width: 100%;
  height: 48px;
  background: var(--surface);
  border: 1.5px solid var(--border-color);
  border-radius: var(--radius-md);
  padding: 0 40px 0 14px;
  font-size: 14px;
  color: var(--text-primary);
  box-sizing: border-box;
}

.password-modal-input:focus {
  border-color: var(--primary-color);
  background: #ffffff;
  box-shadow: 0 0 0 2px rgba(46, 184, 170, 0.2);
}

.password-modal-eye {
  position: absolute;
  right: 8px;
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.password-modal-eye-img {
  width: 18px;
  height: 18px;
}

.password-modal-error {
  margin-top: 8px;
}

.password-modal-error-text {
  font-size: 12px;
  color: var(--danger);
}

.password-modal-footer {
  display: flex;
  border-top: 1px solid var(--border-light);
}

.password-modal-btn {
  flex: 1;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  font-weight: 500;
}

.password-modal-btn-cancel {
  color: var(--text-secondary);
  border-right: 1px solid var(--border-light);
}

.password-modal-btn-confirm {
  color: var(--primary-color);
  font-weight: 600;
}
