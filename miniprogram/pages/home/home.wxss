/* ============================================
   首页 - 视觉优化样式
   设计原则：温暖、可靠、简洁
   特点：信息展示页面，需要清晰的信息层级
   ============================================ */

/* ============================================
   1. 页面容器
   ============================================ */
.container {
  min-height: 100vh;
  padding: var(--spacing-lg);
  padding-bottom: 100px;
  background: var(--background);
}

/* ============================================
   2. 历史报告标题行
   ============================================ */
.section-header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-md);
}

.section-title {
  font-size: var(--font-size-h3);
  font-weight: var(--font-weight-semibold);
  color: var(--text-primary);
}

.add-btn-small {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 8px 18px;
  border: 1.5px solid var(--primary-200);
  border-radius: var(--radius-full);
  background: var(--surface);
  transition: all 0.2s ease;
}

.add-btn-small:active {
  background: var(--primary-50);
  transform: scale(0.96);
}

.add-icon-small {
  font-size: 18px;
  color: var(--primary-color);
  font-weight: 600;
  line-height: 1;
}

.add-text-small {
  font-size: 13px;
  color: var(--primary-color);
  font-weight: 600;
}
.quick-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--spacing-md);
  margin-bottom: var(--spacing-lg);
}

.action-card {
  background: var(--surface);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
  border: 1px solid var(--border-light);
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-base);
}

.action-card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-md);
}

.action-icon-wrapper {
  width: 32px;
  height: 32px;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.action-icon-primary {
  background: var(--primary-50);
}

.action-icon-warning {
  background: var(--warning-bg);
}

.action-icon-text {
  font-size: 16px;
}

.action-content {
  flex: 1;
  min-width: 0;
}

.action-title {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
  color: var(--text-primary);
  display: block;
  margin-bottom: 2px;
}

.action-desc {
  font-size: var(--font-size-xs);
  color: var(--text-muted);
  display: block;
}

/* ============================================
   6. 患者信息卡片
   ============================================ */
.patient-card {
  background: #5ec4a8;
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-lg);
}

.patient-info {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: var(--spacing-md);
  padding-bottom: var(--spacing-md);
  border-bottom: 1px solid rgba(255, 255, 255, 0.3);
}

.patient-main {
  flex: 1;
}

.patient-label {
  font-size: var(--font-size-xs);
  color: rgba(255, 255, 255, 0.85);
  display: block;
  margin-bottom: var(--spacing-xs);
}

.patient-name {
  font-size: var(--font-size-h2);
  font-weight: var(--font-weight-semibold);
  color: #ffffff;
  display: block;
}

.patient-stats {
  text-align: right;
}

.stats-label {
  font-size: var(--font-size-xs);
  color: rgba(255, 255, 255, 0.85);
  display: block;
  margin-bottom: var(--spacing-xs);
}

.stats-value {
  font-size: var(--font-size-h1);
  font-weight: var(--font-weight-bold);
  color: #ffffff;
  display: block;
}

.patient-meta {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
}

.meta-row {
  display: flex;
  align-items: center;
  font-size: var(--font-size-sm);
  color: rgba(255, 255, 255, 0.9);
}

.bell-icon {
  margin-right: var(--spacing-xs);
}

/* ============================================
   7. 报告列表区域
   ============================================ */
.reports-section {
  margin-bottom: var(--spacing-lg);
}

.section-title {
  font-size: var(--font-size-h3);
  font-weight: var(--font-weight-semibold);
  color: var(--text-primary);
  display: block;
  margin-bottom: var(--spacing-md);
}

.reports-content-wrapper {
  position: relative;
  min-height: 200px;
}

/* ============================================
   8. 骨架屏
   ============================================ */
.skeleton-container {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-md);
}

.skeleton-card {
  background: var(--surface);
  border-radius: var(--radius-md);
  padding: var(--spacing-lg);
  border: 1px solid var(--border-light);
}

.skeleton-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: var(--spacing-md);
}

.skeleton-tag {
  width: 60px;
  height: 20px;
  background: var(--hover);
  border-radius: var(--radius-sm);
  animation: skeleton-pulse 1.5s ease-in-out infinite;
}

.skeleton-date {
  width: 80px;
  height: 20px;
  background: var(--hover);
  border-radius: var(--radius-sm);
  animation: skeleton-pulse 1.5s ease-in-out infinite;
}

.skeleton-content {
  display: flex;
  align-items: center;
}

.skeleton-badge {
  width: 100px;
  height: 24px;
  background: var(--hover);
  border-radius: var(--radius-sm);
  animation: skeleton-pulse 1.5s ease-in-out infinite;
}

@keyframes skeleton-pulse {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.5;
  }
}

/* ============================================
   9. 报告列表
   ============================================ */
.reports-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
}

.report-item {
  background: var(--surface);
  border-radius: var(--radius-md);
  border: 1px solid var(--border-light);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
  display: flex;
  align-items: center;
  transition: all var(--transition-base);
}

.report-item:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-md);
}

.report-item-content {
  flex: 1;
  padding: var(--spacing-lg);
  min-width: 0;
}

.report-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-sm);
}

.report-tags {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
}

.report-type {
  font-size: var(--font-size-xs);
  color: var(--text-muted);
  background: var(--hover);
  padding: 2px 8px;
  border-radius: var(--radius-sm);
}

.report-date {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
  font-weight: var(--font-weight-medium);
}

.report-content {
  display: flex;
  align-items: center;
}

.report-badge {
  display: inline-flex;
  align-items: center;
  padding: 4px 12px;
  border-radius: var(--radius-full);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-medium);
}

.badge-success {
  background: var(--success-bg);
  color: var(--success);
}

.badge-warning {
  background: var(--warning-bg);
  color: var(--warning);
}

.report-delete {
  padding: var(--spacing-md);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background var(--transition-fast);
}

.report-delete:active {
  background: var(--danger-bg);
}

.delete-icon {
  font-size: 20px;
  color: var(--text-muted);
  font-weight: var(--font-weight-regular);
}

.report-arrow {
  padding: var(--spacing-md);
  padding-left: 0;
  display: flex;
  align-items: center;
}

.arrow-icon {
  font-size: 16px;
  color: var(--text-muted);
}

/* ============================================
   10. 展开/收起按钮
   ============================================ */
.expand-btn {
  text-align: center;
  padding: var(--spacing-md) 0;
  font-size: var(--font-size-sm);
  color: var(--primary-color);
  font-weight: var(--font-weight-medium);
  border-top: 1px solid var(--divider-color);
  cursor: pointer;
  transition: all var(--transition-base);
}

.expand-btn:active {
  background: var(--hover);
}

/* ============================================
   11. 空状态
   ============================================ */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48px var(--spacing-lg);
  background: var(--surface);
  border-radius: var(--radius-lg);
  border: 1px solid var(--border-light);
}

.empty-icon {
  font-size: 48px;
  margin-bottom: var(--spacing-lg);
  opacity: 0.4;
}

.empty-title {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
  margin-bottom: var(--spacing-xs);
  display: block;
}

.empty-desc {
  font-size: var(--font-size-xs);
  color: var(--text-muted);
  display: block;
}

/* ============================================
   12. 免责声明
   ============================================ */
.disclaimer {
  padding: var(--spacing-lg);
  text-align: center;
  background: rgba(0, 0, 0, 0.03);
  border-radius: 12px;
  margin: var(--spacing-lg);
}

.disclaimer-text {
  font-size: var(--font-size-xs);
  color: var(--text-muted);
  line-height: var(--line-height-relaxed);
}
