.container {
  min-height: 100vh;
  padding: 16px;
  padding-bottom: 100px;
  background: #f8faf9;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}

.title {
  font-size: 20px;
  font-weight: 600;
  color: #1f2937;
}

.add-btn {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: #ffffff;
  border: 1px solid #e5e7eb;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 24px;
  color: #14b8a6;
}

.quick-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
  margin-bottom: 16px;
}

.action-card {
  background: #ffffff;
  border-radius: 12px;
  padding: 12px;
  display: flex;
  align-items: center;
  gap: 12px;
  border: 1px solid #e5e7eb;
}

.action-icon-wrapper {
  width: 32px;
  height: 32px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-icon-primary {
  background: rgba(20, 184, 166, 0.1);
}

.action-icon-warning {
  background: rgba(245, 158, 11, 0.1);
}

.action-icon {
  width: 16px;
  height: 16px;
}

.action-content {
  display: flex;
  flex-direction: column;
}

.action-title {
  font-size: 14px;
  font-weight: 500;
  color: #1f2937;
}

.action-desc {
  font-size: 12px;
  color: #6b7280;
}

.patient-card {
  background: linear-gradient(135deg, #14b8a6 0%, #0d9488 100%);
  border-radius: 16px;
  padding: 20px;
  margin-bottom: 16px;
  color: #ffffff;
}

.patient-info {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16px;
}

.patient-main, .patient-stats {
  display: flex;
  flex-direction: column;
}

.patient-label, .stats-label {
  font-size: 12px;
  opacity: 0.8;
  margin-bottom: 4px;
}

.patient-name {
  font-size: 24px;
  font-weight: 700;
}

.stats-value {
  font-size: 28px;
  font-weight: 700;
  text-align: right;
}

.patient-meta {
  border-top: 1px solid rgba(255, 255, 255, 0.2);
  padding-top: 12px;
}

.meta-row {
  display: flex;
  align-items: center;
  font-size: 14px;
  opacity: 0.9;
  margin-bottom: 8px;
}

.bell-icon {
  width: 14px;
  height: 14px;
  margin-right: 6px;
}

.reports-section {
  margin-bottom: 16px;
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 12px;
  display: block;
}

.reports-list {
  background: #ffffff;
  border-radius: 16px;
  overflow: hidden;
  border: 1px solid #e5e7eb;
}

.report-item {
  padding: 16px;
  border-bottom: 1px solid #e5e7eb;
  display: flex;
  align-items: flex-start;
  position: relative;
}

.report-item:last-child {
  border-bottom: none;
}

.report-item:active {
  background: #f0fdfa;
}

.report-header {
  flex: 1;
}

.report-tags {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 8px;
}

.report-type {
  font-size: 12px;
  padding: 2px 8px;
  border-radius: 4px;
  border: 1px solid #e5e7eb;
  color: #374151;
}

.report-date {
  font-size: 12px;
  color: #6b7280;
}

.report-content {
  display: flex;
  align-items: center;
  gap: 8px;
}

.report-badge {
  padding: 4px 8px;
  border-radius: 8px;
  font-size: 12px;
}

.badge-success {
  background: rgba(34, 197, 94, 0.1);
  color: #16a34a;
}

.badge-warning {
  background: rgba(245, 158, 11, 0.1);
  color: #d97706;
}

.report-summary {
  font-size: 12px;
  color: #6b7280;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.report-arrow {
  color: #d1d5db;
  font-size: 18px;
  margin-left: 8px;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48px 0;
}

.empty-icon {
  width: 48px;
  height: 48px;
  margin-bottom: 12px;
  opacity: 0.4;
}

.empty-title {
  font-size: 14px;
  color: #6b7280;
  margin-bottom: 4px;
}

.empty-desc {
  font-size: 12px;
  color: #9ca3af;
}
