.container {
  min-height: 100vh;
  padding: 16px;
  padding-bottom: 100px;
  background: #f8faf9;
}

.header {
  padding-bottom: 16px;
  margin-bottom: 16px;
}

.title {
  font-size: 20px;
  font-weight: 600;
  color: #1f2937;
}

.patient-card {
  background: linear-gradient(135deg, #14b8a6 0%, #0d9488 100%);
  border-radius: 16px;
  padding: 20px;
  margin-bottom: 16px;
  color: #ffffff;
}

.patient-name {
  font-size: 20px;
  font-weight: 600;
  display: block;
  margin-bottom: 4px;
}

.patient-label {
  font-size: 12px;
  opacity: 0.8;
}

.reminders-section {
  background: #ffffff;
  border-radius: 16px;
  padding: 16px;
  margin-bottom: 16px;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  color: #1f2937;
}

.add-btn {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: #14b8a6;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-icon {
  color: #ffffff;
  font-size: 20px;
}

.reminders-list {
  margin-top: 8px;
}

.reminder-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 0;
  border-bottom: 1px solid #f3f4f6;
}

.reminder-item:last-child {
  border-bottom: none;
}

.reminder-info {
  display: flex;
  flex-direction: column;
}

.reminder-date {
  font-size: 16px;
  font-weight: 500;
  color: #1f2937;
  margin-bottom: 4px;
}

.reminder-time {
  font-size: 14px;
  color: #6b7280;
}

.reminder-actions {
  display: flex;
  align-items: center;
  gap: 12px;
}

.delete-btn {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: #fee2e2;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  color: #dc2626;
  font-size: 16px;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32px 0;
}

.empty-icon {
  width: 48px;
  height: 48px;
  margin-bottom: 12px;
  opacity: 0.4;
}

.empty-title {
  font-size: 14px;
  color: #6b7280;
  margin-bottom: 4px;
}

.empty-desc {
  font-size: 12px;
  color: #9ca3af;
}

.tips-section {
  background: #ffffff;
  border-radius: 16px;
  padding: 16px;
  margin-bottom: 16px;
}

.tips-title {
  font-size: 14px;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 12px;
  display: block;
}

.tips-content {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.tips-text {
  font-size: 13px;
  color: #6b7280;
  line-height: 1.6;
}

.disclaimer {
  padding: 16px 0;
  text-align: center;
}

.disclaimer-text {
  font-size: 12px;
  color: #9ca3af;
  line-height: 1.6;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 80%;
  background: #ffffff;
  border-radius: 16px;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 20px;
  border-bottom: 1px solid #e5e7eb;
}

.modal-title {
  font-size: 16px;
  font-weight: 600;
  color: #1f2937;
}

.modal-close {
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #9ca3af;
  font-size: 20px;
}

.modal-body {
  padding: 20px;
}

.input-group {
  margin-bottom: 8px;
}

.input-label {
  display: block;
  font-size: 14px;
  color: #374151;
  margin-bottom: 8px;
}

.picker-field {
  height: 48px;
  background: #f9fafb;
  border: 1px solid #e5e7eb;
  border-radius: 12px;
  padding: 0 16px;
  display: flex;
  align-items: center;
}

.picker-value {
  font-size: 16px;
  color: #1f2937;
}

.picker-placeholder {
  font-size: 16px;
  color: #9ca3af;
}

.modal-footer {
  display: flex;
  border-top: 1px solid #e5e7eb;
}

.btn-cancel, .btn-confirm {
  flex: 1;
  height: 48px;
  border: none;
  border-radius: 0;
  font-size: 16px;
}

.btn-cancel {
  background: #ffffff;
  color: #6b7280;
  border-right: 1px solid #e5e7eb;
}

.btn-confirm {
  background: #14b8a6;
  color: #ffffff;
}
