<view class="container">
  <view class="header">
    <text class="title">提醒设置</text>
  </view>

  <view class="patient-card" wx:if="{{patient}}">
    <text class="patient-name">{{patient.name}}</text>
    <text class="patient-label">当前患者</text>
  </view>

  <view class="reminders-section">
    <view class="section-header">
      <text class="section-title">复查提醒</text>
      <view class="add-btn" bindtap="handleAddReminder">
        <text class="add-icon">+</text>
      </view>
    </view>

    <view class="reminders-list" wx:if="{{reminders.length > 0}}">
      <view class="reminder-item" wx:for="{{reminders}}" wx:key="reminder_id">
        <view class="reminder-info">
          <text class="reminder-date">{{item.reminder_date}}</text>
          <text class="reminder-time">{{item.reminder_time}}</text>
        </view>
        <view class="reminder-actions">
          <switch checked="{{item.is_enabled}}" color="#14b8a6" bindchange="handleToggleReminder" data-id="{{item.reminder_id}}" />
          <view class="delete-btn" bindtap="handleDeleteReminder" data-id="{{item.reminder_id}}">
            <text class="delete-icon">×</text>
          </view>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:else>
      <image src="/images/icon-bell-empty.svg" class="empty-icon"></image>
      <text class="empty-title">暂无提醒</text>
      <text class="empty-desc">点击右上角添加复查提醒</text>
    </view>
  </view>

  <view class="tips-section">
    <text class="tips-title">温馨提示</text>
    <view class="tips-content">
      <text class="tips-text">• 提醒将在设定日期当天通过微信服务通知推送</text>
      <text class="tips-text">• 请确保已开启小程序通知权限</text>
      <text class="tips-text">• 建议在化疗后7-14天进行血常规复查</text>
    </view>
  </view>

  <view class="disclaimer">
    <text class="disclaimer-text">本工具仅供内部测试与健康科普参考，不构成任何诊疗建议</text>
  </view>
</view>

<view class="modal-mask" wx:if="{{showModal}}" bindtap="handleCloseModal">
  <view class="modal-content" catchtap>
    <view class="modal-header">
      <text class="modal-title">添加提醒</text>
      <view class="modal-close" bindtap="handleCloseModal">
        <text>×</text>
      </view>
    </view>
    
    <view class="modal-body">
      <view class="input-group">
        <text class="input-label">提醒日期</text>
        <picker mode="date" value="{{newReminder.date}}" bindchange="onDateChange">
          <view class="picker-field">
            <text class="{{newReminder.date ? 'picker-value' : 'picker-placeholder'}}">
              {{newReminder.date || '请选择日期'}}
            </text>
          </view>
        </picker>
      </view>

      <view class="input-group mt-3">
        <text class="input-label">提醒时间</text>
        <picker mode="time" value="{{newReminder.time}}" bindchange="onTimeChange">
          <view class="picker-field">
            <text class="{{newReminder.time ? 'picker-value' : 'picker-placeholder'}}">
              {{newReminder.time || '请选择时间'}}
            </text>
          </view>
        </picker>
      </view>
    </view>

    <view class="modal-footer">
      <button class="btn-cancel" bindtap="handleCloseModal">取消</button>
      <button class="btn-confirm" bindtap="handleConfirmAdd">确定</button>
    </view>
  </view>
</view>
