<view class="container page-enter">

  <view class="indicator-tabs">
    <scroll-view scroll-x class="tabs-scroll">
      <view class="tabs-list">
        <view 
          class="tab-item {{currentCode === item.code ? 'active' : ''}}" 
          wx:for="{{references}}" 
          wx:key="code"
          bindtap="handleTabChange"
          data-code="{{item.code}}"
        >
          <text>{{item.shortName}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="content-section" wx:if="{{currentReference}}">
    <view class="description-card">
      <text class="description-title">{{currentReference.name}}</text>
      <text class="description-label">临床意义</text>
      <text class="description-text">{{currentReference.clinicalSignificance}}</text>
    </view>

    <view class="grades-section">
      <text class="section-title">WHO骨髓抑制分级标准</text>
      
      <view class="grade-card grade-{{item.level}}" 
            wx:for="{{currentReference.grades}}" 
            wx:key="levelName"
            bindtap="handleGradeClick"
            data-grade="{{item}}">
        <view class="grade-header">
          <view class="grade-level-badge grade-badge-{{item.level}}">
            <text>{{item.levelName}}</text>
          </view>
          <text class="grade-range">{{item.range}} {{currentReference.unit}}</text>
        </view>
        <view class="grade-content">
          <text class="grade-principle">{{item.principle}}</text>
          <view class="grade-advice" wx:if="{{item.dischargeAdvice}}">
            <text class="grade-advice-label">💡 出院医嘱</text>
            <text class="grade-advice-text">{{item.dischargeAdvice}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="tips-section" wx:if="{{currentReference.careTips}}">
      <text class="section-title">居家护理建议</text>
      
      <view class="tips-list">
        <view class="tip-item" wx:for="{{currentReference.careTips}}" wx:key="index">
          <text class="tip-bullet">•</text>
          <text class="tip-text">{{item}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="disclaimer disclaimer-tabbar">
    <text class="disclaimer-text">{{disclaimer}}</text>
  </view>
</view>
