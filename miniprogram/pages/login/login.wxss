.container {
  min-height: 100vh;
  padding: 32px 24px;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #f0fdfa 0%, #ffffff 100%);
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 48px;
  padding-bottom: 32px;
}

.logo-icon {
  width: 80px;
  height: 80px;
  border-radius: 20px;
  background: linear-gradient(135deg, #14b8a6 0%, #0d9488 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8px 24px rgba(20, 184, 166, 0.3);
  margin-bottom: 16px;
}

.logo-image {
  width: 40px;
  height: 40px;
}

.app-title {
  font-size: 28px;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 4px;
}

.app-subtitle {
  font-size: 14px;
  color: #6b7280;
}

.form-section {
  flex: 1;
  padding-top: 16px;
}

.input-group {
  margin-bottom: 8px;
}

.input-label {
  display: block;
  font-size: 14px;
  font-weight: 500;
  color: #374151;
  margin-bottom: 8px;
}

.input-field {
  width: 100%;
  height: 48px;
  background: #ffffff;
  border: 1px solid #e5e7eb;
  border-radius: 12px;
  padding: 0 16px;
  font-size: 16px;
  color: #1f2937;
  box-sizing: border-box;
}

.input-field:focus {
  border-color: #14b8a6;
  outline: none;
}

.input-field::placeholder {
  color: #9ca3af;
}

.password-input-wrapper {
  position: relative;
}

.password-input {
  padding-right: 48px;
}

.password-toggle {
  position: absolute;
  right: 12px;
  top: 50%;
  transform: translateY(-50%);
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.toggle-icon {
  width: 20px;
  height: 20px;
}

.btn-login {
  width: 100%;
  height: 48px;
  background: #14b8a6;
  border-radius: 24px;
  border: none;
  color: #ffffff;
  font-size: 16px;
  font-weight: 600;
  margin-top: 24px;
}

.btn-login:active {
  background: #0f766e;
}

.btn-login[loading] {
  opacity: 0.7;
}

.agreement-text {
  text-align: center;
  margin-top: 16px;
}

.agreement-text text {
  font-size: 12px;
  color: #9ca3af;
}

.disclaimer-section {
  padding: 16px 0;
  margin-top: auto;
}

.disclaimer-text {
  font-size: 12px;
  color: #9ca3af;
  text-align: center;
  line-height: 1.8;
}
