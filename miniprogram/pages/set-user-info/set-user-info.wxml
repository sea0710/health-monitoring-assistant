<view class="container page-enter">

  <view class="header-section animate-fade-in">
    <text class="header-title">完善个人信息</text>
    <text class="header-subtitle">设置您的头像和昵称，让体验更完整</text>
  </view>

  <view class="form-card animate-slide-up">
    <view class="avatar-section">
      <text class="input-label">头像</text>
      <button class="avatar-btn btn-press" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image class="avatar-image" src="{{avatarUrl || '/images/logo.svg'}}" mode="aspectFill"></image>
        <view class="avatar-edit-badge">
          <image class="avatar-edit-icon" src="/images/icon-camera.svg" mode="aspectFit"></image>
        </view>
      </button>
      <text class="avatar-hint">点击更换头像</text>
    </view>

    <view class="divider"></view>

    <view class="input-group">
      <text class="input-label">昵称</text>
      <input
        class="input-field input-glow"
        type="nickname"
        placeholder="请输入昵称"
        value="{{nickname}}"
        bindinput="onNicknameInput"
        bindblur="onNicknameBlur"
      />
    </view>
  </view>

  <view class="privacy-notice animate-fade-in">
    <text class="privacy-icon">◈</text>
    <text class="privacy-text">您的个人信息仅用于展示，我们不会向第三方泄露您的隐私数据</text>
  </view>

  <view class="action-section">
    <button class="btn-primary btn-press" bindtap="saveUserInfo" loading="{{isLoading}}" disabled="{{isLoading}}">
      {{isLoading ? '保存中...' : '保存信息'}}
    </button>
  </view>

</view>
