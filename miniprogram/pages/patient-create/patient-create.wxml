<view class="container">
  <view class="header">
    <view class="back-btn" bindtap="handleBack">
      <text class="back-icon">‹</text>
      <text class="back-text">返回</text>
    </view>
    <text class="title">创建患者档案</text>
    <view class="placeholder"></view>
  </view>

  <view class="form-section">
    <view class="input-group">
      <text class="input-label">患者姓名 *</text>
      <input 
        class="input-field" 
        placeholder="请输入患者姓名" 
        value="{{name}}"
        bindinput="onNameInput"
      />
    </view>

    <view class="input-group mt-3">
      <text class="input-label">性别</text>
      <view class="gender-selector">
        <view class="gender-option {{gender === '男' ? 'active' : ''}}" bindtap="onGenderSelect" data-gender="男">
          <text>男</text>
        </view>
        <view class="gender-option {{gender === '女' ? 'active' : ''}}" bindtap="onGenderSelect" data-gender="女">
          <text>女</text>
        </view>
      </view>
    </view>

    <view class="input-group mt-3">
      <text class="input-label">出生日期</text>
      <picker mode="date" value="{{birthday}}" bindchange="onBirthdayChange">
        <view class="picker-field">
          <text class="{{birthday ? 'picker-value' : 'picker-placeholder'}}">
            {{birthday || '请选择出生日期'}}
          </text>
        </view>
      </picker>
    </view>

    <view class="input-group mt-3">
      <text class="input-label">肿瘤类型</text>
      <input 
        class="input-field" 
        placeholder="请输入肿瘤类型（可选）" 
        value="{{tumorType}}"
        bindinput="onTumorTypeInput"
      />
    </view>

    <view class="input-group mt-3">
      <text class="input-label">治疗方案</text>
      <input 
        class="input-field" 
        placeholder="请输入治疗方案（可选）" 
        value="{{treatmentPlan}}"
        bindinput="onTreatmentPlanInput"
      />
    </view>

    <view class="input-group mt-3">
      <text class="input-label">化疗周期数</text>
      <input 
        class="input-field" 
        type="number" 
        placeholder="请输入当前化疗周期数" 
        value="{{chemotherapyCycles}}"
        bindinput="onChemotherapyCyclesInput"
      />
    </view>

    <view class="input-group mt-3">
      <text class="input-label">最近化疗结束时间</text>
      <picker mode="date" value="{{lastChemoEndDate}}" bindchange="onLastChemoEndDateChange">
        <view class="picker-field">
          <text class="{{lastChemoEndDate ? 'picker-value' : 'picker-placeholder'}}">
            {{lastChemoEndDate || '请选择化疗结束日期'}}
          </text>
        </view>
      </picker>
    </view>
  </view>

  <view class="action-section">
    <button class="btn-primary" bindtap="handleSave" loading="{{isLoading}}">
      {{isLoading ? '保存中...' : '保存档案'}}
    </button>
  </view>

  <view class="disclaimer">
    <text class="disclaimer-text">本工具仅供内部测试与健康科普参考，不构成任何诊疗建议</text>
  </view>
</view>
