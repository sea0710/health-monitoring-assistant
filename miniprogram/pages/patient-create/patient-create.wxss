.container {
  min-height: 100vh;
  padding: 16px;
  background: #f8faf9;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 16px;
  border-bottom: 1px solid #e5e7eb;
  margin-bottom: 16px;
}

.back-btn {
  display: flex;
  align-items: center;
  padding: 8px;
  margin-left: -8px;
}

.back-icon {
  font-size: 20px;
  color: #14b8a6;
  margin-right: 4px;
}

.back-text {
  font-size: 14px;
  color: #14b8a6;
}

.title {
  font-size: 18px;
  font-weight: 600;
  color: #1f2937;
}

.placeholder {
  width: 60px;
}

.form-section {
  background: #ffffff;
  border-radius: 16px;
  padding: 20px;
  margin-bottom: 16px;
}

.input-group {
  margin-bottom: 8px;
}

.input-label {
  display: block;
  font-size: 14px;
  font-weight: 500;
  color: #374151;
  margin-bottom: 8px;
}

.input-field {
  width: 100%;
  height: 48px;
  background: #f9fafb;
  border: 1px solid #e5e7eb;
  border-radius: 12px;
  padding: 0 16px;
  font-size: 16px;
  color: #1f2937;
  box-sizing: border-box;
}

.input-field:focus {
  border-color: #14b8a6;
  background: #ffffff;
}

.gender-selector {
  display: flex;
  gap: 12px;
}

.gender-option {
  flex: 1;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f9fafb;
  border: 1px solid #e5e7eb;
  border-radius: 12px;
  font-size: 16px;
  color: #6b7280;
}

.gender-option.active {
  background: rgba(20, 184, 166, 0.1);
  border-color: #14b8a6;
  color: #14b8a6;
}

.picker-field {
  width: 100%;
  height: 48px;
  background: #f9fafb;
  border: 1px solid #e5e7eb;
  border-radius: 12px;
  padding: 0 16px;
  display: flex;
  align-items: center;
}

.picker-value {
  font-size: 16px;
  color: #1f2937;
}

.picker-placeholder {
  font-size: 16px;
  color: #9ca3af;
}

.action-section {
  padding: 16px 0;
}

.btn-primary {
  width: 100%;
  height: 48px;
  background: #14b8a6;
  border-radius: 24px;
  border: none;
  color: #ffffff;
  font-size: 16px;
  font-weight: 600;
}

.btn-primary:active {
  background: #0f766e;
}

.btn-primary[loading] {
  opacity: 0.7;
}

.disclaimer {
  padding: 16px 0;
  text-align: center;
}

.disclaimer-text {
  font-size: 12px;
  color: #9ca3af;
  line-height: 1.6;
}
