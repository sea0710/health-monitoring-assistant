.container {
  min-height: 100vh;
  background: var(--background);
  display: flex;
  flex-direction: column;
}

.profile-header-card {
  position: relative;
  border-radius: var(--radius-xl);
  margin: var(--spacing-lg);
  margin-top: 0;
  overflow: hidden;
}

.profile-header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--primary-50);
  z-index: 0;
}

.profile-header-content {
  position: relative;
  z-index: 1;
  padding: 20px 20px;
}

.profile-top-row {
  display: flex;
  align-items: center;
  gap: 14px;
}

.avatar-btn {
  width: 60px !important;
  height: 60px !important;
  border-radius: 50% !important;
  overflow: hidden !important;
  padding: 0 !important;
  margin: 0 !important;
  background: rgba(20, 184, 166, 0.1) !important;
  border: 2px solid rgba(20, 184, 166, 0.2) !important;
  line-height: normal !important;
  box-sizing: border-box !important;
  position: relative !important;
  display: block !important;
  flex-shrink: 0;
}

.avatar-btn::after {
  border: none !important;
}

.avatar-image {
  width: 56px !important;
  height: 56px !important;
  border-radius: 50% !important;
  display: block !important;
  margin: auto !important;
  object-fit: cover !important;
}

.avatar-edit-overlay {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.overlay-text {
  font-size: 12px;
  color: var(--primary-foreground, #ffffff);
  font-weight: 500;
}

.avatar-check-badge {
  position: absolute;
  bottom: 1px; right: 1px;
  width: 18px; height: 18px;
  background: var(--success);
  border-radius: 50%;
  border: 2px solid var(--surface, #ffffff);
  display: flex;
  align-items: center;
  justify-content: center;
}

.check-icon {
  color: var(--primary-foreground, #ffffff);
  font-size: 12px;
  font-weight: 700;
}

.profile-nickname-section {
  flex: 1;
  min-width: 0;
}

.nickname-input-field {
  width: 100%;
  height: 36px;
  font-size: 16px;
  font-weight: 600;
  color: var(--text-primary);
  text-align: left;
  padding: 0 8px;
  border-bottom: 1px solid rgba(20, 184, 166, 0.25);
  background: transparent;
  box-sizing: border-box;
}

.nickname-input-field:focus {
  border-bottom-color: rgba(20, 184, 166, 0.6);
}

.nickname-input-field::placeholder {
  color: var(--text-muted);
  font-weight: 400;
  font-size: 14px;
}

.profile-status-row {
  display: flex;
  gap: 6px;
  margin-top: 6px;
}

.status-tag {
  padding: 1px 8px;
  border-radius: 8px;
  font-size: 12px;
}

.status-ok {
  background: var(--success-bg);
}

.status-ok text {
  color: var(--success);
  font-weight: 500;
}

.status-empty {
  background: var(--warning-bg);
}

.status-empty text {
  color: var(--warning);
  font-weight: 500;
}

.save-btn-wrap {
  width: 100%;
  margin-top: 20px;
}

.btn-save-profile {
  width: 200px;
  height: 48px;
  background: var(--primary-color);
  color: var(--primary-foreground, #ffffff);
  border-radius: 24px;
  font-size: 14px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto;
  padding: 0;
  line-height: 48px;
  border: none;
}

.btn-save-profile::after {
  border: none;
}

.btn-save-profile:active {
  background: var(--primary-dark);
  transform: scale(0.97);
}

.section-card {
  background: var(--surface);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
  margin: 0 var(--spacing-lg) var(--spacing-lg);
  overflow: hidden;
}

.section-title-row {
  display: flex;
  align-items: center;
  padding: 16px 20px 8px;
}

.section-icon-wrap {
  width: 28px;
  height: 28px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 10px;
  flex-shrink: 0;
}

.section-icon-patient {
  background: rgba(20, 184, 166, 0.1);
}

.section-icon-security {
  background: rgba(245, 158, 11, 0.1);
}

.section-icon-img {
  width: 18px;
  height: 18px;
}

.section-title-text {
  font-size: 16px;
  font-weight: 600;
  color: var(--text-primary);
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 20px;
  border-bottom: 1px solid var(--divider-color, rgba(0, 0, 0, 0.06));
  transition: background 0.15s;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: var(--hover, rgba(0, 0, 0, 0.03));
}

.menu-item-danger {
  background: rgba(239, 68, 68, 0.03);
}

.menu-item-danger:active {
  background: rgba(239, 68, 68, 0.08);
}

.menu-text-danger {
  font-size: 16px;
  color: var(--danger);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.menu-desc-danger {
  font-size: 12px;
  color: var(--danger);
  opacity: 0.7;
  margin-top: 2px;
  display: block;
}

.menu-arrow-danger {
  color: var(--danger);
}

.menu-left {
  flex: 1;
  min-width: 0;
}

.menu-text {
  font-size: 16px;
  color: var(--text-primary);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.menu-desc {
  font-size: 12px;
  color: var(--text-muted);
  margin-top: 2px;
  display: block;
}

.menu-arrow-wrap {
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 8px;
  flex-shrink: 0;
}

.menu-arrow-icon {
  font-size: 18px;
  color: var(--text-muted);
}

.logout-section {
  margin: var(--spacing-xl) var(--spacing-lg);
}

.btn-logout {
  width: 100%;
  height: 48px;
  background: var(--surface);
  border: 1px solid var(--border-color, #e5e7eb);
  border-radius: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  color: var(--danger);
  font-weight: 500;
  transition: all 0.15s;
}

.btn-logout:active {
  background: rgba(239, 68, 68, 0.05);
  transform: scale(0.98);
}

.disclaimer-text {
  font-size: var(--font-size-xs);
  color: var(--text-muted);
  line-height: var(--line-height-relaxed);
}
