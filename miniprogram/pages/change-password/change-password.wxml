<view class="container page-enter">
  <view class="header">
    <text class="title">修改密码</text>
    <text class="subtitle">定期修改密码可以提高账户安全性</text>
  </view>

  <view class="form-section">
    <view class="form-item">
      <text class="form-label">原密码 <text class="required">*</text></text>
      <input 
        type="password"
        placeholder="请输入当前密码"
        value="{{oldPassword}}"
        bindinput="onOldPasswordInput"
        class="form-input"
      />
    </view>

    <view class="form-item">
      <text class="form-label">新密码 <text class="required">*</text></text>
      <input 
        type="password"
        placeholder="请输入新密码（至少6位）"
        value="{{newPassword}}"
        bindinput="onNewPasswordInput"
        class="form-input"
      />
    </view>

    <view class="form-item">
      <text class="form-label">确认新密码 <text class="required">*</text></text>
      <input 
        type="password"
        placeholder="请再次输入新密码"
        value="{{confirmPassword}}"
        bindinput="onConfirmPasswordInput"
        class="form-input"
      />
    </view>

    <button 
      class="btn-primary btn-bottom" 
      bindtap="handleChangePassword" 
      loading="{{isChanging}}"
      disabled="{{!canSubmit}}"
    >
      {{isChanging ? '修改中...' : '确认修改'}}
    </button>
  </view>
</view>