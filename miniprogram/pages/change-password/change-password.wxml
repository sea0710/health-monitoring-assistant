<view class="container page-enter">

  <view class="header-section animate-fade-in">
    <text class="header-title">修改密码</text>
    <text class="header-subtitle">请输入当前密码和新密码完成修改</text>
  </view>

  <view class="form-card animate-slide-up">
    <view class="input-group">
      <text class="input-label">当前密码</text>
      <view class="password-input-wrapper">
        <input
          class="input-field password-input input-glow"
          type="{{showOldPassword ? 'text' : 'password'}}"
          placeholder="请输入当前密码"
          value="{{oldPassword}}"
          bindinput="onOldPasswordInput"
        />
        <view class="password-toggle btn-press" bindtap="toggleOldPassword">
          <image
            src="{{showOldPassword ? '/images/eye-off.svg' : '/images/eye.svg'}}"
            class="toggle-icon"
          ></image>
        </view>
      </view>
    </view>

    <view class="divider"></view>

    <view class="input-group">
      <text class="input-label">新密码</text>
      <view class="password-input-wrapper">
        <input
          class="input-field password-input input-glow"
          type="{{showNewPassword ? 'text' : 'password'}}"
          placeholder="请输入新密码（至少6位，含数字和字母）"
          value="{{newPassword}}"
          bindinput="onNewPasswordInput"
        />
        <view class="password-toggle btn-press" bindtap="toggleNewPassword">
          <image
            src="{{showNewPassword ? '/images/eye-off.svg' : '/images/eye.svg'}}"
            class="toggle-icon"
          ></image>
        </view>
      </view>
    </view>

    <view class="input-group">
      <text class="input-label">确认新密码</text>
      <view class="password-input-wrapper">
        <input
          class="input-field password-input input-glow"
          type="{{showConfirmPassword ? 'text' : 'password'}}"
          placeholder="请再次输入新密码"
          value="{{confirmPassword}}"
          bindinput="onConfirmPasswordInput"
        />
        <view class="password-toggle btn-press" bindtap="toggleConfirmPassword">
          <image
            src="{{showConfirmPassword ? '/images/eye-off.svg' : '/images/eye.svg'}}"
            class="toggle-icon"
          ></image>
        </view>
      </view>
    </view>
  </view>

  <view class="action-section">
    <button class="btn-primary btn-press" bindtap="handleChange" loading="{{isLoading}}" disabled="{{isLoading}}">
      {{isLoading ? '修改中...' : '确认修改'}}
    </button>
  </view>

</view>
